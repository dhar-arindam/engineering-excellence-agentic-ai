# ─────────────────────────────────────────────────────────────────────────────
# ai-multi-agent — Monorepo environment variables
#
# Copy to .env and fill in the values before running `docker compose up`.
# Never commit the real .env file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
LOG_LEVEL=INFO
SECRET_KEY=change-me-in-production

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_multi_agent
# Used by the FastAPI backend (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ai_multi_agent

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── LLM (OpenAI-compatible) ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3

# ── GitHub integration ────────────────────────────────────────────────────────
# Personal-access token used for cloning private repos and posting PR comments.
GITHUB_TOKEN=your_github_pat_here

# ── Review / scan settings ────────────────────────────────────────────────────
MAX_CONCURRENT_AGENTS=5
REVIEW_TIMEOUT_SECONDS=300
SCAN_MAX_CONCURRENT=3
SCAN_TIMEOUT_SECONDS=600
SCAN_LOCK_TTL_SECONDS=660
SCAN_QUEUE_NAME=arq:scans

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Public URL of the FastAPI backend reachable from the browser.
# In Docker Compose this is the exposed port on the host.
NEXT_PUBLIC_API_URL=http://localhost:8000
