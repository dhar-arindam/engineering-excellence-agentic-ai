{
  "name": "ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "fetch:openapi": "curl http://localhost:8000/openapi.json -o src/generated/openapi.json",
    "generate:types": "openapi-typescript src/generated/openapi.json --output src/generated/api-types.ts",
    "generate:client": "openapi-typescript-codegen --input src/generated/openapi.json --output src/generated/api-client --client fetch",
    "generate:api": "npm run fetch:openapi && npm run generate:types && npm run generate:client"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "optionalDependencies": {
    "@azure/msal-browser": "^5.8.0"
  }
}
