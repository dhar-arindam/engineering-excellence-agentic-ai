# ─────────────────────────────────────────────────────────────────────────────
# ui — Next.js environment variables
#
# Copy to .env.local for local development:
#   cp .env.example .env.local
#
# HOW IT WORKS (runtime-configurable, no rebuild needed):
#   The root layout.tsx (Server Component) reads NEXT_PUBLIC_API_URL from
#   process.env at request time and injects it into window.__ENV. The client
#   bundle reads window.__ENV first, so changing this variable only requires
#   restarting the container — not rebuilding the image.
#
# In Docker Compose, set NEXT_PUBLIC_API_URL in the `environment:` block.
# Never commit .env.local.
# ─────────────────────────────────────────────────────────────────────────────

# Public URL of the FastAPI backend as seen by the browser.
# WebSocket connections (scan log streaming) are derived automatically:
#   http://... → ws://...
#   https://... → wss://...
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Authentication mode ──────────────────────────────────────────────────────
#
# local  → No MSAL. Fetches identity from /api/auth/local-user (OS username).
#          Falls back to { name: "Local Developer", email: "dev@localhost" }.
# azure  → MSAL / Azure AD. Requires @msal/browser + NEXT_PUBLIC_AZURE_* vars.
#
NEXT_PUBLIC_AUTH_MODE=local

# ─── Azure AD (only required when NEXT_PUBLIC_AUTH_MODE=azure) ───────────────
# Install:  npm install @msal/browser
# NEXT_PUBLIC_AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# NEXT_PUBLIC_AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# NEXT_PUBLIC_AZURE_SCOPES=User.Read,api://<client-id>/access_as_user
